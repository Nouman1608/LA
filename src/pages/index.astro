---
import HomeLayout from '../layouts/HomeLayout.astro';
import Hero from '../components/sections/Hero.astro';
import BoardStrip from '../components/sections/BoardStrip.astro';
import AboutWhyUs from '../components/sections/AboutWhyUs.astro';
import Boards from '../components/sections/Boards.astro';
import Subjects from '../components/sections/Subjects.astro';
import Team from '../components/sections/Team.astro';
import Pricing from '../components/sections/Pricing.astro';
import TrialContact from '../components/sections/TrialContact.astro';

const title = 'Online IGCSE, O & A Level Tuition Pakistan | Learners Academy';
const description =
  'Live online IGCSE, O Level and A Level classes across Cambridge, Edexcel and AQA — expert teachers, 23 subjects, transparent pricing. Book a free demo class.';
---
<HomeLayout title={title} description={description} canonical="/">
  <Hero />
  <BoardStrip />
  <AboutWhyUs />
  <Boards />
  <Subjects />
  <Team />
  <Pricing />
  <TrialContact />
</HomeLayout>
