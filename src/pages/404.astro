---
import HomeLayout from '../layouts/HomeLayout.astro';
import Button from '../components/ui/Button.astro';
import { site } from '../data/site';
---
<HomeLayout
  title={`Page not found | ${site.name}`}
  description="The page you were looking for could not be found."
  canonical="/404/"
  topBar={false}
  noindex
>
  <section class="nf">
    <div class="container nf__inner">
      <p class="nf__code">404</p>
      <h1 class="nf__title">We couldn't find that page.</h1>
      <p class="nf__sub">It may have moved. Try the homepage or browse our subjects.</p>
      <div class="nf__cta">
        <Button href="/" variant="primary" size="lg">Go home</Button>
        <Button href="/subjects/" variant="ghost" size="lg">Browse subjects</Button>
      </div>
    </div>
  </section>
</HomeLayout>

<style>
  .nf {
    background: var(--c-bg);
    padding-block: 120px;
  }
  .nf__inner {
    text-align: center;
    max-width: 560px;
  }
  .nf__code {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 72px;
    color: var(--c-accent);
    line-height: 1;
  }
  .nf__title {
    margin: 12px 0 0;
    font-size: clamp(28px, 4vw, 40px);
  }
  .nf__sub {
    margin: 16px 0 28px;
    font-size: 17px;
  }
  .nf__cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
