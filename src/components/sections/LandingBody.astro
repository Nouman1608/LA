---
import Button from '../ui/Button.astro';

interface Point {
  title: string;
  body: string;
}
interface RelatedLink {
  label: string;
  href: string;
}
interface Props {
  lead: string;
  pointsTitle?: string;
  points: Point[];
  relatedTitle?: string;
  related?: RelatedLink[];
}
const {
  lead,
  pointsTitle = 'What you get',
  points,
  relatedTitle,
  related = [],
} = Astro.props;
---
<section class="lbody">
  <div class="container container--narrow">
    <p class="lbody__lead">{lead}</p>

    <h2 class="lbody__h2">{pointsTitle}</h2>
    <div class="lbody__grid">
      {
        points.map((p) => (
          <div class="lcard">
            <h3 class="lcard__title">{p.title}</h3>
            <p class="lcard__body">{p.body}</p>
          </div>
        ))
      }
    </div>

    {
      related.length > 0 && (
        <div class="related">
          <h2 class="lbody__h2">{relatedTitle ?? 'Explore subjects'}</h2>
          <div class="related__links">
            {related.map((r) => (
              <a class="related__link" href={r.href}>
                {r.label}
                <span aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class="lbody__cta">
      <Button href="/contact/" variant="primary" size="lg">Book a free trial class</Button>
    </div>
  </div>
</section>

<style>
  .lbody {
    background: var(--c-bg);
    padding-block: var(--section-y);
  }
  .lbody__lead {
    margin: 0 auto;
    max-width: 70ch;
    font-size: clamp(18px, 1.9vw, 21px);
    line-height: 1.7;
    color: var(--c-text);
  }
  .lbody__h2 {
    margin: 56px 0 24px;
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.1;
    color: var(--c-primary);
  }
  .lbody__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 18px;
  }
  .lcard {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    padding: 24px;
    box-shadow: var(--shadow-card);
  }
  .lcard__title {
    margin: 0 0 10px;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 20px;
    color: var(--c-primary);
  }
  .lcard__body {
    margin: 0;
    line-height: 1.65;
    color: var(--c-text);
    font-size: 15.5px;
  }
  .related__links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .related__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-pill);
    padding: 10px 18px;
    font-weight: 600;
    font-size: 15px;
    color: var(--c-primary);
  }
  .related__link:hover {
    border-color: var(--c-accent-soft);
  }
  .lbody__cta {
    margin-top: 48px;
    text-align: center;
  }
</style>
