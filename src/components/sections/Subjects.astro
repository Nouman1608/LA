---
import Section from '../ui/Section.astro';
import Pill from '../ui/Pill.astro';
import { getCollection } from 'astro:content';

const subjects = (await getCollection('subjects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const count = subjects.length;
const juniors = ['Maths', 'Science', 'English', 'Computer Science'];
---
<Section id="subjects" tone="panel">
  <div class="subjects__head">
    <div class="subjects__heading">
      <p class="eyebrow">Subjects</p>
      <h2 class="section-title">{count} subjects across IGCSE &amp; A Level.</h2>
    </div>
    <a href="/subjects/" class="subjects__all">Browse all subjects →</a>
  </div>

  <div class="subjects__grid">
    {
      subjects.map((s) => (
        <a href={`/subjects/${s.id}/`} class="subject">
          <span>{s.data.name}</span>
          <span class="subject__arrow" aria-hidden="true">→</span>
        </a>
      ))
    }
  </div>

  <div class="juniors">
    <div>
      <h3 class="juniors__title">Junior classes too</h3>
      <p class="juniors__sub">
        Maths · Science · English · Computer Science — building strong foundations early.
      </p>
    </div>
    <div class="juniors__pills">
      {juniors.map((j) => <Pill tone="soft">{j}</Pill>)}
    </div>
  </div>
</Section>

<style>
  .subjects__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .subjects__heading {
    max-width: 620px;
  }
  .subjects__all {
    color: var(--c-primary);
    font-weight: 700;
    border-bottom: 2px solid var(--c-primary);
    padding-bottom: 3px;
  }
  .subjects__grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .subject {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 16px 18px;
    font-size: 15.5px;
    font-weight: 500;
    color: var(--c-primary-ink);
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .subject:hover {
    border-color: var(--c-accent);
    transform: translateY(-2px);
  }
  .subject__arrow {
    color: var(--c-accent-soft);
  }

  .juniors {
    margin-top: 34px;
    padding: 24px 26px;
    background: var(--c-primary);
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .juniors__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 20px;
    color: #fff;
  }
  .juniors__sub {
    margin: 6px 0 0;
    font-size: 14.5px;
    color: var(--c-on-primary-soft);
  }
  .juniors__pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
</style>
