---
import { site } from '../../data/site';
interface Props {
  /** 'light' = indigo logo for light surfaces (header); 'invert' = white logo (footer). */
  tone?: 'light' | 'invert';
  /** Kept for backward-compatibility. The logo image already contains the wordmark. */
  withTagline?: boolean;
  href?: string;
}
const { tone = 'light', href = '/' } = Astro.props;
const src = tone === 'invert' ? '/logo-white.png' : '/logo-indigo.png';
---
<a class:list={['logo', `logo--${tone}`]} href={href} aria-label={`${site.name} — home`}>
  <img class="logo__img" src={src} alt="" width="665" height="580" decoding="async" />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo__img {
    height: 44px;
    width: auto;
    display: block;
  }
  /* Footer version a touch larger on its dark panel */
  .logo--invert .logo__img {
    height: 52px;
  }
  @media (max-width: 640px) {
    .logo__img { height: 38px; }
    .logo--invert .logo__img { height: 46px; }
  }
</style>
