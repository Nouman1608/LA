---
import BaseLayout from './BaseLayout.astro';
import TopBar from '../components/layout/TopBar.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { educationalOrganization } from '../components/seo/schemas';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  /** Show the contact top bar (homepage only by default). */
  topBar?: boolean;
}
const { title, description, canonical, ogImage, ogType, noindex, topBar = true } = Astro.props;
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType={ogType}
  noindex={noindex}
>
  <JsonLd slot="head" data={educationalOrganization()} />
  <slot name="head" slot="head" />
  {topBar && <TopBar />}
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</BaseLayout>
