---
import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';
import WhatsAppFab from '../components/layout/WhatsAppFab.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  narrow?: boolean;
}

const { title, description, canonical, ogImage, ogType, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#47589b" />
    <meta name="google-site-verification" content="D6H7tzldgQpKogFROlLAP5_mY8-1P1u_P5kEx1WWmUc" />
    <meta name="msvalidate.01" content="E1E4888EF12475D9F4206730B8754EA2" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    <slot name="head" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QCC7YN632L"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QCC7YN632L');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    <WhatsAppFab />
  </body>
</html>
